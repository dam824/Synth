// Schéma Prisma pour SYNTH (PostgreSQL).
// binaryTargets : "native" pour le dev local (macOS/Linux),
// "linux-musl-openssl-3.0.x" pour l'image Docker Alpine en production.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Rôles & sécurité
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
  SUPPORT
}

enum AdminAuditAction {
  VIEW_METADATA
  BREAK_GLASS_VIEW_CONTENT
  EXPORT_USER_DATA
  DELETE_CONVERSATION
  SUSPEND_USER
  SAFETY_OVERRIDE
}

enum SafetyDecision {
  ALLOW
  WARN
  BLOCK
  ESCALATE
}

// ---------------------------------------------------------------------------
// Authentification (Auth.js / NextAuth + adaptateur Prisma)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  suspended     Boolean   @default(false)

  accounts Account[]
  sessions Session[]

  conversations       Conversation[]
  projects            Project[]
  usageLogs           UsageLog[]
  safetyLogs          SafetyLog[]
  wallet              Wallet?
  creditLedger        CreditLedger[]
  billingCustomer     BillingCustomer?
  billingSubscription BillingSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Crédits & facturation
// ---------------------------------------------------------------------------

model Wallet {
  id                String   @id @default(cuid())
  userId            String   @unique
  balance           Int      @default(0)
  lifetimePurchased Int      @default(0)
  lifetimeSpent     Int      @default(0)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CreditLedger {
  id              String   @id @default(cuid())
  userId          String
  type            String
  amount          Int
  balanceAfter    Int
  status          String   @default("completed")
  reason          String?
  planKey         String?
  stripeSessionId String?
  stripePaymentId String?
  stripeInvoiceId String?
  idempotencyKey  String   @unique
  metadata        Json?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([stripePaymentId])
  @@index([stripeInvoiceId])
}

model BillingCustomer {
  id               String   @id @default(cuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BillingSubscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeSubscriptionId String    @unique
  stripePriceId        String
  planKey              String
  status               String
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domaine SYNTH
// ---------------------------------------------------------------------------

// Dossier / projet regroupant des conversations.
model Project {
  id     String @id @default(cuid())
  userId String
  name   String @default("Nouveau projet")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Conversation {
  id        String  @id @default(cuid())
  userId    String
  title     String  @default("Nouvelle conversation")
  pinned    Boolean @default(false)
  archived  Boolean @default(false)
  projectId String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  prompts Prompt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}

model Prompt {
  id                String  @id @default(cuid())
  conversationId    String
  // Contenu en clair : conservé pour les anciens enregistrements (lecture).
  // Les nouveaux prompts laissent ce champ vide et remplissent les colonnes
  // chiffrées ci-dessous.
  content           String? @db.Text
  contentEncrypted  String? @db.Text
  contentNonce      String?
  contentKeyVersion Int     @default(1)

  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  modelResponses ModelResponse[]
  finalAnswer    FinalAnswer?
  usageLogs      UsageLog[]

  createdAt DateTime @default(now())

  @@index([conversationId])
}

// Réponse brute d'un fournisseur IA pour un prompt donné.
model ModelResponse {
  id                String  @id @default(cuid())
  promptId          String
  provider          String // "openai" | "anthropic" | "gemini"
  model             String? // identifiant exact du modèle utilisé
  content           String? @db.Text // legacy clair (anciens enregistrements)
  contentEncrypted  String? @db.Text
  contentNonce      String?
  contentKeyVersion Int     @default(1)
  success           Boolean @default(false)
  error             String? @db.Text // message d'erreur (métadonnée, non chiffré)
  latencyMs         Int?

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([promptId])
}

// Réponse finale unique produite par le Juge.
model FinalAnswer {
  id                String  @id @default(cuid())
  promptId          String  @unique
  content           String? @db.Text // legacy clair (anciens enregistrements)
  contentEncrypted  String? @db.Text
  contentNonce      String?
  contentKeyVersion Int     @default(1)
  confidence        String // "high" | "medium" | "low"
  disagreements     String? @db.Text // JSON sérialisé (liste de désaccords)
  usedProviders     String // JSON sérialisé (liste des fournisseurs exploités)

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Journal d'utilisation (base pour facturation / quotas futurs).
model UsageLog {
  id                 String  @id @default(cuid())
  userId             String
  promptId           String?
  providersAttempted Int     @default(0)
  providersSucceeded Int     @default(0)
  confidence         String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt Prompt? @relation(fields: [promptId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([promptId])
}

// ---------------------------------------------------------------------------
// Admin & safety (journaux append-only, sans contenu en clair)
// ---------------------------------------------------------------------------

// Journal d'audit : toute action admin sensible y est tracée.
model AdminAuditLog {
  id             String           @id @default(cuid())
  adminId        String
  adminEmail     String?
  targetUserId   String?
  conversationId String?
  action         AdminAuditAction
  reason         String?          @db.Text
  metadata       String?          @db.Text

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([conversationId])
}

// Journal des décisions de modération (pré/post). Ne stocke pas de contenu.
model SafetyLog {
  id       String         @id @default(cuid())
  userId   String
  promptId String?
  stage    String // "pre" | "post"
  decision SafetyDecision
  category String?
  metadata String?        @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([promptId])
}
