# ======================================================================
# SYNTH — Exemple de configuration d'environnement
# Copier ce fichier vers .env puis remplir les valeurs.
# Ne JAMAIS committer le fichier .env réel.
# ======================================================================

# ----------------------------------------------------------------------
# Base de données PostgreSQL
# En local, Postgres tourne dans Docker (voir docker-compose.yml).
# ----------------------------------------------------------------------
POSTGRES_USER=synth
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=synth
POSTGRES_PORT=5432

# Chaîne de connexion utilisée par Prisma.
# En local : host = localhost. En prod Docker : host = postgres (nom du service).
DATABASE_URL="postgresql://synth:change_me_in_real_env@localhost:5432/synth?schema=public"

# ----------------------------------------------------------------------
# Auth.js / NextAuth (v5)
# ----------------------------------------------------------------------
# Secret de signature des sessions. Générer avec : openssl rand -base64 32
AUTH_SECRET=change_me_generate_with_openssl

# URL publique de l'application (obligatoire en production).
# Local : http://localhost:3000
AUTH_URL=http://localhost:3000

# OAuth Google
# Callback local : http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OAuth GitHub
# Callback local : http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ----------------------------------------------------------------------
# Crédits / facturation
# ----------------------------------------------------------------------
# Nombre de crédits offerts au premier accès utilisateur.
FREE_GRANT_CREDITS=100

# Prix par défaut de la génération principale si la base n'a pas encore été seedée.
CREDITS_DEFAULT_FEATURE_PRICE=15

# Devise utilisée pour les packs et Checkout.
STRIPE_CURRENCY=eur

# URL publique de l'app utilisée pour les redirections Checkout.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Chemins de retour Stripe après paiement.
STRIPE_CHECKOUT_SUCCESS_PATH=/tarifs?checkout=success
STRIPE_CHECKOUT_CANCEL_PATH=/tarifs?checkout=cancel

# Clé publique Stripe si le client en a besoin.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Clé serveur Stripe.
STRIPE_SECRET_KEY=

# Secret de signature du webhook Stripe.
# Local : stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------
# Fournisseurs IA
# ----------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_GPT_55_MODEL=gpt-5.5
OPENAI_GPT_54_MODEL=gpt-5.4
OPENAI_GPT_54_MINI_MODEL=gpt-5.4-mini

# Anthropic Claude (aussi utilisé par le Juge)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_OPUS_48_MODEL=claude-opus-4-8
ANTHROPIC_SONNET_46_MODEL=claude-sonnet-4-6
ANTHROPIC_HAIKU_45_MODEL=claude-haiku-4-5

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_31_FLASH_LITE_MODEL=gemini-3.1-flash-lite
GEMINI_35_FLASH_MODEL=gemini-3.5-flash
GEMINI_31_PRO_MODEL=gemini-3.1-pro

# Modèle utilisé par le Juge (synthèse finale). Par défaut : ANTHROPIC_MODEL.
JUDGE_MODEL=claude-opus-4-8

# Mémoire conversationnelle envoyée aux modèles.
# SYNTH inclut toute la conversation tant qu'elle rentre dans ce budget.
CONVERSATION_MEMORY_CHAR_BUDGET=18000
CONVERSATION_MEMORY_TURN_WARNING=18
