# ======================================================================
# SYNTH — Exemple de configuration d'environnement
# Copier ce fichier vers .env puis remplir les valeurs.
# Ne JAMAIS committer le fichier .env réel.
# ======================================================================

# ----------------------------------------------------------------------
# Base de données PostgreSQL
# En local, Postgres tourne dans Docker (voir docker-compose.yml).
# ----------------------------------------------------------------------
POSTGRES_USER=synth
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=synth
POSTGRES_PORT=5432

# Chaîne de connexion utilisée par Prisma.
# En local : host = localhost. En prod Docker : host = postgres (nom du service).
DATABASE_URL="postgresql://synth:change_me_in_real_env@localhost:5432/synth?schema=public"

# ----------------------------------------------------------------------
# Auth.js / NextAuth (v5)
# ----------------------------------------------------------------------
# Secret de signature des sessions. Générer avec : openssl rand -base64 32
AUTH_SECRET=change_me_generate_with_openssl

# URL publique de l'application (obligatoire en production).
# Local : http://localhost:3000
AUTH_URL=http://localhost:3000

# OAuth Google
# Callback local : http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OAuth GitHub
# Callback local : http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ----------------------------------------------------------------------
# Fournisseurs IA
# ----------------------------------------------------------------------
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude (aussi utilisé par le Juge)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Modèle utilisé par le Juge (synthèse finale). Par défaut : ANTHROPIC_MODEL.
JUDGE_MODEL=claude-opus-4-8
